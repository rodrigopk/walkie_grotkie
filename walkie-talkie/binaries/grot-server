#!/usr/bin/env bash
# Development sidecar wrapper for the Grot WebSocket server.
#
# Tauri spawns this script as if it were a native binary during `cargo tauri dev`.
# In production, replace this with a PyInstaller-bundled binary (see Phase 5 /
# build-sidecar.sh).
#
# Usage: grot-server [--port PORT] [--api-key KEY] [...]
#   All arguments are passed through to `idotmatrix-upload serve`.

set -euo pipefail

# Navigate to the project root (two levels up from walkie-talkie/binaries/).
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "${SCRIPT_DIR}/../.." && pwd)"
cd "${PROJECT_ROOT}"

# Activate the project virtual environment if present.
if [[ -f "${PROJECT_ROOT}/.venv/bin/activate" ]]; then
    # shellcheck source=/dev/null
    source "${PROJECT_ROOT}/.venv/bin/activate"
fi

# Kill any orphaned server process holding the target port (default 8765).
# This prevents "address already in use" errors on hot-reload or crashes.
_PORT=8765
for _arg in "$@"; do
    case "$_arg" in --port) _NEXT_IS_PORT=1 ;; *)
        if [[ "${_NEXT_IS_PORT:-}" == "1" ]]; then _PORT="$_arg"; unset _NEXT_IS_PORT; fi ;;
    esac
done
_PIDS="$(lsof -ti :"${_PORT}" 2>/dev/null || true)"
if [[ -n "$_PIDS" ]]; then
    echo "Killing existing process(es) on port ${_PORT}: ${_PIDS}" >&2
    echo "$_PIDS" | xargs kill -TERM 2>/dev/null || true
    sleep 0.5
fi

exec python -m idotmatrix_upload serve "$@"
