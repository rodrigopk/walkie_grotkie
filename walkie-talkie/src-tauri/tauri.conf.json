{
  "$schema": "https://schema.tauri.app/config/2.0.0.json",
  "productName": "Grot Walkie-Talkie",
  "version": "0.1.0",
  "identifier": "com.grot.walkie-talkie",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "macOSPrivateApi": true,
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "Grot Walkie-Talkie",
        "width": 400,
        "height": 700,
        "resizable": false,
        "center": true,
        "decorations": false,
        "transparent": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [],
    "externalBin": ["binaries/grot-server"]
  }
}
