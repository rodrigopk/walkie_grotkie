{
  "$schema": "../node_modules/@tauri-apps/cli/schema/acl/capability.json",
  "identifier": "default",
  "description": "Default capabilities for Grot Walkie-Talkie",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "core:window:allow-close",
    "shell:allow-spawn",
    "shell:allow-kill",
    "shell:allow-stdin-write"
  ]
}
